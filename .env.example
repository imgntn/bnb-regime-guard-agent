# CoinMarketCap data.
# Use CMC_API_KEY for REST mode, or set CMC_USE_X402=1 to use the CMC x402 MCP path.
CMC_API_KEY=
CMC_USE_X402=0
CMC_X402_TRANSPORT=quotes
CMC_X402_QUOTES_URL=https://pro-api.coinmarketcap.com/x402/v3/cryptocurrency/quotes/latest
CMC_X402_MCP_URL=https://mcp.coinmarketcap.com/x402/mcp
CMC_X402_TOOL_NAME=cryptocurrency_quotes_latest
CMC_X402_FALLBACK=1
X402_NETWORK=eip155:8453
X402_WALLET_ADDRESS=
X402_PRIVATE_KEY=
X402_MAX_USDC_PER_REQUEST=0.02
BASE_RPC_URL=https://mainnet.base.org

# TWAK CLI execution. Leave TWAK_BIN empty to use: npx -y @trustwallet/cli
# TW_ACCESS_ID/TW_HMAC_SECRET aliases are also accepted for local compatibility.
TWAK_BIN=
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_WALLET_PASSWORD=

# Live trading is opt-in and requires both values.
LIVE_TRADING=0
TWAK_CONFIRM_LIVE=

# Agent risk limits.
COMPETITION_MODE=1
COMPETITION_MAX_USD_PER_TRADE=8
COMPETITION_SIZE_MULTIPLIER=1.6
COMPETITION_MIN_SIZING_SCORE=95
COMPETITION_MIN_SIZING_CONFIDENCE=90
MAX_USD_PER_TRADE=5
MAX_DAILY_TRADES=2
DAILY_TRADE_FLOOR=1
QUALIFICATION_TRADE_USD=1.25
QUALIFICATION_MAX_ROUND_TRIP_DRAG_PCT=0.6
MAX_DAILY_LOSS_PCT=4
MAX_WEEKLY_DRAWDOWN_PCT=8
POSITION_STOP_LOSS_PCT=6
TAKE_PROFIT_PCT=4
MAX_POSITION_HOLD_HOURS=36
SLIPPAGE_PCT=0.75

# Optional BNB Agent SDK identity registration.
AGENT_WALLET_ADDRESS=
AGENT_CARD_URI=https://raw.githubusercontent.com/imgntn/bnb-regime-guard-agent/main/docs/agent-card.json
WALLET_PASSWORD=
PRIVATE_KEY=
NETWORK=bsc-mainnet
