# CoinMarketCap data.
# Use CMC_API_KEY for REST mode, or set CMC_USE_X402=1 to route requests through TWAK x402.
CMC_API_KEY=
CMC_USE_X402=0

# TWAK CLI execution. Leave TWAK_BIN empty to use: npx -y @trustwallet/cli
TWAK_BIN=
TWAK_WALLET_PASSWORD=

# Live trading is opt-in and requires both values.
LIVE_TRADING=0
TWAK_CONFIRM_LIVE=

# Agent risk limits.
MAX_USD_PER_TRADE=5
MAX_DAILY_TRADES=1
MAX_DAILY_LOSS_PCT=4
MAX_WEEKLY_DRAWDOWN_PCT=8
SLIPPAGE_PCT=0.75

# Optional BNB Agent SDK identity registration.
WALLET_PASSWORD=
PRIVATE_KEY=
NETWORK=bsc-mainnet

